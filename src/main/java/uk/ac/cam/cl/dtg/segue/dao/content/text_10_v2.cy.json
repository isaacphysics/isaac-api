          "explanation": {
            "type": "content",
            "children": [
              {
                "type": "content",
                "value": "Gellir defnyddio fersiwn 32-bit o Unicode i gynrychioli hyd at 2<sup>32</sup> o nodau!",
                "encoding": "markdown"
              }
            ],
            "encoding": "markdown"
          },
