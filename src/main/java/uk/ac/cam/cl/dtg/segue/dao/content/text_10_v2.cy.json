      "id": "text_10_v2|c1be32b2-a9b1-4c7a-b769-e626fe35b6b8",
      "items": [
        {
          "type": "item",
          "value": "Mae set nodau Unicode fel arfer yn defnyddio 16 bit fesul nod.",
          "id": "26d8"
        },
        {
          "type": "item",
          "value": "Gellir defnyddio Unicode i gynrychioli hyd at 256 o nodau gwahanol.",
          "id": "253c"
        },
        {
          "type": "item",
          "value": "Mae ASCII yn gallu cynrychioli nodau o ieithoedd heblaw Saesneg.",
          "id": "3242"
        },
        {
          "type": "item",
          "value": "Mae ASCII Estynedig yn defnyddio 8 bit i gynrychioli pob nod.",
          "id": "cfde"
        },
        {
          "type": "item",
          "id": "e632",
          "value": "Defnyddir y 128 cod cyntaf yn ASCII ac Unicode i gynrychioli'r un nodau. "
        }
